# ---------------------------------------------------------------------------
# Element 26 environment variables
# ---------------------------------------------------------------------------

# SERVER-SIDE ONLY — set this in the Vercel project's Environment Variables,
# NOT in any VITE_ variable and NOT in frontend code. It is read only by the
# serverless function in api/. Never commit a real key.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: restrict which origin may call the proxy (defaults to "*").
# Set this to your app's origin (e.g. https://prospercode11.github.io) once
# you know where the app is hosted.
# ALLOWED_ORIGIN=https://prospercode11.github.io

# ---------------------------------------------------------------------------
# FRONTEND (Vite) — safe to expose; these ship in the browser bundle.
# ---------------------------------------------------------------------------

# Where the frontend sends AI requests. Leave unset when the app and the proxy
# are deployed together on Vercel (defaults to same-origin /api/generate-program).
# Set it to the full proxy URL if the app is hosted elsewhere (e.g. GitHub Pages)
# and the proxy is on Vercel:
# VITE_AI_ENDPOINT=https://your-project.vercel.app/api/generate-program
